# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server
PORT=5001
FLASK_DEBUG=False
SECRET_KEY=generate-a-long-random-string

# Database (SQLite for local; Postgres URL for production)
DATABASE_URL=sqlite:///court_kiosk.db

# CORS — comma-separated frontend origins (do NOT use * in production)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Bootstrap admin (required to create the first admin user; never commit real passwords)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@court.gov
ADMIN_PASSWORD=

# Optional: restrict which admins can use the dashboard
# ADMIN_WHITELIST=admin
# ADMIN_WHITELIST_EMAILS=admin@court.gov

# Optional shared secret for kiosk LLM/email endpoints (sent as X-Kiosk-Key)
# When set, frontend must set REACT_APP_KIOSK_API_KEY to the same value.
KIOSK_API_KEY=

# OpenAI
OPENAI_API_KEY=sk-...

# Email (Resend preferred)
RESEND_API_KEY=
RESEND_FROM_DOMAIN=
RESEND_FROM_EMAIL=
FACILITATOR_EMAIL=

# Legacy SMTP (optional fallback)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Rate limiting (optional Redis / Postgres URI)
# RATELIMIT_STORAGE_URL=redis://localhost:6379
